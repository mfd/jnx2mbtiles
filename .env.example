# Telegram bot token from @BotFather
BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrSTUvwxYZ

# Local Bot API server URL — снимает лимит 50 МБ, поднимает до 2 ГБ
# Без этой переменной бот работает через официальный API (лимит 50 МБ)
LOCAL_API_URL=http://localhost:8081

# Публичный адрес VPS — если задан, бот дополнительно шлёт HTTP-ссылку для скачивания
# Если не задан, только файл через Telegram
VPS_URL=http://1.2.3.4:8080

# Порт HTTP-сервера для скачивания (default: 8080)
# HTTP_PORT=8080

# Сколько часов хранить файл по ссылке (default: 2)
# EXPIRE_HOURS=2
